# Root .gitignore for LMS Project (Laravel Backend + Next.js Frontend)

# --- General ---
Plan.md
.DS_Store
.idea/
.vscode/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# --- Backend (Laravel) ---
backend/vendor/
backend/node_modules/
backend/.env
backend/.env.backup
backend/.env.production
backend/bootstrap/cache/*.php
backend/storage/framework/cache/data/*
backend/storage/framework/sessions/*
backend/storage/framework/testing/*
backend/storage/framework/views/*.php
backend/storage/logs/*.log
backend/storage/app/public/*
backend/public/storage
backend/.phpunit.result.cache
backend/.phpunit.cache/
backend/auth.json

# --- Frontend (Next.js) ---
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/build/
frontend/.env.local
frontend/.env.development.local
frontend/.env.test.local
frontend/.env.production.local
frontend/.vercel
frontend/*.tsbuildinfo
frontend/next-env.d.ts
